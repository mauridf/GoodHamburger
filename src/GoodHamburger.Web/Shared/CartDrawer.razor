@inject CartService CartService
@inject OrderApiService OrderService
@inject ISnackbar Snackbar

<MudPaper Class="pa-4">

    <MudText Typo="Typo.h5" Class="mb-3">
        Carrinho
    </MudText>

    @if (!CartService.Items.Any())
    {
        <MudText>Carrinho vazio</MudText>
    }
    else
    {
        @foreach (var item in CartService.Items)
        {
            <MudPaper Class="pa-2 mb-2">

                <MudText>@item.Name</MudText>

                <MudText>
                    @item.Quantity x R$ @item.UnitPrice.ToString("0.00")
                </MudText>

                <MudButton Size="Size.Small"
                           OnClick="() => CartService.Decrease(item.MenuItemId)">
                    -
                </MudButton>

                <MudButton Size="Size.Small"
                           OnClick="() => CartService.Increase(item.MenuItemId)">
                    +
                </MudButton>

            </MudPaper>
        }

        <MudDivider Class="my-3" />

        <MudText>
            Subtotal: R$ @CartService.Subtotal.ToString("0.00")
        </MudText>

        @if (_result is not null)
        {
            <MudText Color="Color.Warning">
                Desconto: R$ @_result.Discount.ToString("0.00")
            </MudText>

            <MudText Typo="Typo.h6">
                Total: R$ @_result.Total.ToString("0.00")
            </MudText>
        }

        <MudButton FullWidth="true"
                   Color="Color.Success"
                   Variant="Variant.Filled"
                   Class="mt-3"
                   Disabled="_loading"
                   OnClick="FinishOrder">

            Finalizar Pedido

        </MudButton>
    }

</MudPaper>

@code {
    private bool _loading;
    private OrderResponseModel? _result;

    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged;
    }

    private async Task FinishOrder()
    {
        try
        {
            _loading = true;

            var request = new CreateOrderRequest
            {
                Items = CartService.Items.Select(x =>
                    new CreateOrderItemRequest
                    {
                        MenuItemId = x.MenuItemId,
                        Quantity = x.Quantity
                    }).ToList()
            };

            _result = await OrderService.CreateAsync(request);

            CartService.Clear();

            Snackbar.Add("Pedido realizado com sucesso!", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Erro ao finalizar pedido.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }
}