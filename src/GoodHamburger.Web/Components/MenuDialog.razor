@using MudBlazor
@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@using GoodHamburger.Web.Helpers

@inject MenuApiService MenuService
@inject ISnackbar Snackbar

<MudDialog>

    <DialogContent>

        <MudTextField Label="Nome"
                      @bind-Value="Model.Name"
                      Required="true"
                      Margin="Margin.Dense" />

        <MudTextField Label="Descrição"
                      @bind-Value="Model.Description"
                      Margin="Margin.Dense" />

        <MudNumericField T="decimal"
                         Label="Preço"
                         @bind-Value="Model.Price"
                         Required="true"
                         Margin="Margin.Dense" />

        <MudTextField Label="Imagem URL"
                      @bind-Value="Model.ImageUrl"
                      Margin="Margin.Dense" />

        <MudSelect T="int"
                   Label="Categoria"
                   @bind-Value="SelectedCategory"
                   Margin="Margin.Dense">

            @foreach (var category in CategoryHelper.Map)
            {
                <MudSelectItem Value="@category.Key">
                    @category.Value
                </MudSelectItem>
            }

        </MudSelect>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <MudPaper Class="pa-2 mt-4">
                <img src="@Model.ImageUrl"
                     style="max-width:100%; height:150px; object-fit:cover;" />
            </MudPaper>
        }

    </DialogContent>

    <DialogActions>

        <MudButton OnClick="Cancel">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   OnClick="Save">

            Salvar

        </MudButton>

    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    public MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public MenuItemModel Model { get; set; } = new();

    private int SelectedCategory
    {
        get => Model.Category switch
        {
            "Sandwich" => 1,
            "Side" => 2,
            "Drink" => 3,
            _ => 1
        };

        set => Model.Category = value switch
        {
            1 => "Sandwich",
            2 => "Side",
            3 => "Drink",
            _ => "Sandwich"
        };
    }

    private async Task Save()
    {
        if (Model.Id == Guid.Empty)
        {
            await MenuService.CreateAsync(Model);
            Snackbar.Add("Item criado com sucesso", Severity.Success);
        }
        else
        {
            await MenuService.UpdateAsync(Model);
            Snackbar.Add("Item atualizado com sucesso", Severity.Success);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}