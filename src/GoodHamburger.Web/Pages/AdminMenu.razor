@page "/admin/menu"

@inject MenuApiService MenuService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">
    Administração do Cardápio
</MudText>

<MudTextField Placeholder="Buscar..."
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              @bind-Value="_search"
              Class="mb-3" />

<MudButton Color="Color.Primary"
           Variant="Variant.Filled"
           OnClick="OpenCreateDialog">
    Novo Item
</MudButton>

<MudTable Items="FilteredItems" Hover="true" Dense="true">

    <HeaderContent>
        <MudTh>Imagem</MudTh>
        <MudTh>Nome</MudTh>
        <MudTh>Preço</MudTh>
        <MudTh>Categoria</MudTh>
        <MudTh>Ações</MudTh>
    </HeaderContent>

    <RowTemplate>

        <MudTd>
            <img src="@context.ImageUrl" width="60" />
        </MudTd>

        <MudTd>@context.Name</MudTd>

        <MudTd>
            R$ @context.Price.ToString("0.00")
        </MudTd>

        <MudTd>
            @CategoryHelper.Map[context.Category]
        </MudTd>

        <MudTd>

            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           OnClick="() => OpenEditDialog(context)" />

            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           OnClick="() => ConfirmDelete(context.Id)" />

        </MudTd>

    </RowTemplate>

</MudTable>

@code {
    private List<MenuItemModel> _items = new();
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _items = await MenuService.GetAllAsync();
    }

    private IEnumerable<MenuItemModel> FilteredItems =>
        _items.Where(x =>
            string.IsNullOrWhiteSpace(_search) ||
            x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private async Task Reload()
    {
        _items = await MenuService.GetAllAsync();
        StateHasChanged();
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters
        {
            ["Model"] = new MenuItemModel()
        };

        var dialog = DialogService.Show<MenuDialog>("Novo Item", parameters);

        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            await Reload();
        }
    }

    private async Task OpenEditDialog(MenuItemModel item)
    {
        var parameters = new DialogParameters
        {
            ["Model"] = item
        };

        var dialog = DialogService.Show<MenuDialog>("Editar Item", parameters);

        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            await Reload();
        }
    }

    private async Task ConfirmDelete(Guid id)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmar",
            "Deseja realmente excluir?",
            yesText: "Sim",
            cancelText: "Cancelar");

        if (result == true)
        {
            await MenuService.DeleteAsync(id);
            Snackbar.Add("Item removido", Severity.Warning);
            await Reload();
        }
    }
}