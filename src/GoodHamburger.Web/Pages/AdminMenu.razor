@page "/admin/menu"

@inject MenuApiService MenuService
@inject ISnackbar Snackbar

<PageTitle>Admin Menu</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    Administração do Cardápio
</MudText>

<MudButton Color="Color.Primary"
           Variant="Variant.Filled"
           OnClick="NewItem"
           Class="mb-4">
    Novo Item
</MudButton>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="_items" Hover="true" Dense="true">

        <HeaderContent>
            <MudTh>Imagem</MudTh>
            <MudTh>Nome</MudTh>
            <MudTh>Preço</MudTh>
            <MudTh>Categoria</MudTh>
            <MudTh>Ações</MudTh>
        </HeaderContent>

        <RowTemplate>

            <MudTd>
                <img src="@context.ImageUrl"
                     width="60" />
            </MudTd>

            <MudTd>@context.Name</MudTd>

            <MudTd>
                R$ @context.Price.ToString("0.00")
            </MudTd>

            <MudTd>@context.Category</MudTd>

            <MudTd>

                <MudButton Size="Size.Small"
                           Color="Color.Info"
                           OnClick="() => Edit(context)">
                    Editar
                </MudButton>

                <MudButton Size="Size.Small"
                           Color="Color.Error"
                           OnClick="() => Remove(context.Id)">
                    Excluir
                </MudButton>

            </MudTd>

        </RowTemplate>

    </MudTable>
}

<MudDivider Class="my-4" />

<MudPaper Class="pa-4">

    <MudText Typo="Typo.h6">
        @_title
    </MudText>

    <MudTextField Label="Nome" @bind-Value="_model.Name" />
    <MudTextField Label="Descrição" @bind-Value="_model.Description" />
    <MudTextField Label="Preço" @bind-Value="_model.Price" />
    <MudTextField Label="Imagem URL" @bind-Value="_model.ImageUrl" />

    <MudSelect T="string"
               Label="Categoria"
               @bind-Value="_model.Category">

        <MudSelectItem Value="Sandwich">Sandwich</MudSelectItem>
        <MudSelectItem Value="Side">Side</MudSelectItem>
        <MudSelectItem Value="Drink">Drink</MudSelectItem>

    </MudSelect>

    @if (!string.IsNullOrWhiteSpace(_model.ImageUrl))
    {
        <img src="@_model.ImageUrl"
             width="180"
             class="mt-3" />
    }

    <MudButton Color="Color.Success"
               Variant="Variant.Filled"
               Class="mt-4"
               OnClick="Save">
        Salvar
    </MudButton>

</MudPaper>

@code {
    private List<MenuItemModel> _items = new();
    private bool _loading = true;

    private MenuItemModel _model = new();

    private string _title = "Novo Item";

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _items = await MenuService.GetAllAsync();
        _loading = false;
        StateHasChanged();
    }

    private void NewItem()
    {
        _model = new MenuItemModel();
        _title = "Novo Item";
    }

    private void Edit(MenuItemModel item)
    {
        _model = new MenuItemModel
        {
            Id = item.Id,
            Name = item.Name,
            Description = item.Description,
            Price = item.Price,
            ImageUrl = item.ImageUrl,
            Category = item.Category
        };

        _title = "Editar Item";
    }

    private async Task Save()
    {
        if (_model.Id == Guid.Empty)
        {
            _model.Id = Guid.NewGuid();
            await MenuService.CreateAsync(_model);
            Snackbar.Add("Item criado com sucesso", Severity.Success);
        }
        else
        {
            await MenuService.UpdateAsync(_model);
            Snackbar.Add("Item atualizado com sucesso", Severity.Success);
        }

        NewItem();
        await Load();
    }

    private async Task Remove(Guid id)
    {
        await MenuService.DeleteAsync(id);

        Snackbar.Add("Item removido", Severity.Warning);

        await Load();
    }
}