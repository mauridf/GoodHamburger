@page "/"
@inject MenuApiService MenuService

@inject CartService CartService
@inject ISnackbar Snackbar

@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services

<PageTitle>Good Hamburger</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    Nosso Cardápio
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
}
else if (!_items.Any())
{
    <MudAlert Severity="Severity.Warning">
        Nenhum item encontrado.
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var item in _items)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="ma-2">

                    <MudCardMedia Image="@item.ImageUrl"
                                  Height="220" />

                    <MudCardContent>

                        <MudText Typo="Typo.h6">
                            @item.Name
                        </MudText>

                        <MudText Typo="Typo.body2" Class="mb-2">
                            @item.Description
                        </MudText>

                        <MudChip Color="Color.Secondary" Variant="Variant.Filled">
                            @item.Category
                        </MudChip>

                        <MudText Typo="Typo.h6" Class="mt-3">
                            R$ @item.Price.ToString("0.00")
                        </MudText>

                    </MudCardContent>

                    <MudCardActions>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="() => AddToCart(item)">
                            Adicionar
                        </MudButton>

                    </MudCardActions>

                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<MenuItemModel> _items = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _items = await MenuService.GetAllAsync();
        _loading = false;
    }

    private void AddToCart(MenuItemModel item)
    {
        CartService.Add(item);
        Snackbar.Add("Item adicionado ao carrinho", Severity.Success);
    }
}